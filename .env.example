# ============================================================
#  PODO - Gestionale Podologi  |  Configurazione ambiente
#  Copia questo file in ".env" e compila i valori.
#  NON committare mai il file .env reale.
# ============================================================

APP_NAME="Podo"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Rome
APP_URL=https://podo.example.it
APP_LOCALE=it
APP_FALLBACK_LOCALE=it

# Forza HTTPS (obbligatorio in produzione — checklist: TLS 1.3)
# Il TLS è terminato da Nginx Proxy Manager (NPM) a monte; l'app resta HTTP interno.
FORCE_HTTPS=true

# ---------------- Reverse proxy (Nginx Proxy Manager) ----------------
# L'app sta dietro NPM che gestisce il certificato Let's Encrypt e inoltra
# X-Forwarded-Proto=https. Laravel si fida del proxy (trustProxies) e riconosce HTTPS.
#
# NOTA per un test locale SENZA NPM (accesso diretto http://IP:8080):
#   imposta  FORCE_HTTPS=false  e  SESSION_SECURE_COOKIE=false
#   altrimenti il cookie di sessione non viaggia su HTTP e il login va in loop.

# ---------------- Logging / Audit ----------------
LOG_CHANNEL=stack
LOG_STACK=daily,audit
LOG_LEVEL=warning
# Conservazione log applicativi (giorni)
LOG_DAILY_DAYS=90

# ---------------- Database (PostgreSQL) ----------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=podo
DB_USERNAME=podo
DB_PASSWORD=change_me_strong_password
# Cifratura connessione DB (checklist: crittografia in transito)
DB_SSLMODE=prefer

# ---------------- Cache / Code / Sessioni ----------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------- Cifratura dati a riposo ----------------
# Chiave usata dai cast "encrypted" (AES-256). Deve essere presente in APP_KEY.
# Per campi sensibili aggiuntivi vedi config/podo.php

# ---------------- Posta (notifiche, reset password) ----------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.it
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@podo.example.it"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------- WhatsApp Business Cloud API (Meta) ----------------
# Promemoria appuntamenti. Richiede numero e template approvati.
WHATSAPP_ENABLED=false
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=promemoria_appuntamento
WHATSAPP_TEMPLATE_LANG=it
# Ore prima dell'appuntamento in cui inviare il promemoria
WHATSAPP_REMINDER_HOURS_BEFORE=24

# ---------------- Google Calendar ----------------
# Sincronizzazione agenda. Percorso al JSON delle credenziali OAuth.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/oauth/google/callback"
GOOGLE_CALENDAR_ID=primary

# ---------------- Sicurezza / Autenticazione ----------------
# MFA TOTP obbligatoria per ruoli privilegiati (checklist: MFA)
MFA_REQUIRED_FOR_ADMINS=true
# Rate limiting login (tentativi/minuto)
LOGIN_RATE_LIMIT=5
# Password policy minima
PASSWORD_MIN_LENGTH=12

# ---------------- Backup (spatie/laravel-backup) ----------------
BACKUP_ENABLED=true
BACKUP_ENCRYPTION_PASSWORD=change_me_backup_password
# Destinazione off-site (S3 compatibile). Vuoto = solo locale.
BACKUP_DISK=local
